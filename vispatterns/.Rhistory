GNET_pilot_RUN1_alldata$DTN_byPhase <- 0
for (i in 1:nrow(GNET_pilot_RUN1_alldata)){
for (j in 1:nrow(difference_indices)){
if (grepl(difference_indices$pict[j],GNET_pilot_RUN1_alldata$stim[i])){
GNET_pilot_RUN1_alldata$DTF[i] <- difference_indices$DTF[j]
GNET_pilot_RUN1_alldata$DTAF[i] <- difference_indices$DTAF[j]
GNET_pilot_RUN1_alldata$DTAN[i] <- difference_indices$DTAN[j]
GNET_pilot_RUN1_alldata$DTN_byPhase[i] <- difference_indices$DTN_byPhase[j]
