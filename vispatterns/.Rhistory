rm(i,j)
GNET_pilot_alldata <- GNET_pilot_RUN1_alldata
rm(GNET_pilot_RUN1_alldata)
ids <- GNET_pilot_alldata[, .(rowCount = .N), by = c("ID","datetime")]
# extract the number of all separate runs - allruns
allruns <- unique(GNET_pilot_alldata[,c("ID")])
allruns <- na.omit(allruns)
allruns <- nrow(allruns)
GNET_pilot_alldata$response <- paste(GNET_pilot_alldata$study_response,GNET_pilot_alldata$test_response)
# REMOVE TOO MUCH MISSED RESPONSES
ResponsesSummary <- GNET_pilot_alldata[, .(rowCount = .N), by = .(ID,type,tq,response)]
MissedResSummary <- ResponsesSummary[response == "None", sum(rowCount),by = .(ID)]
MissedResSummary <- MissedResSummary[V1 < 66,]
GNET_pilot_alldata <-
GNET_pilot_alldata[(ID %in% MissedResSummary$workerId),]
# Nr of exclusions due to misses
ExcludeMisses <- nrow(ids) - nrow(MissedResSummary)
# túl alacsony prototype recog rate a study alatt kipottyan
StudySummary <- GNET_pilot_alldata[is.na(count_test_sequence) & response == "left" & type == "prototype", .N/25, by=.(ID)]
StudyFA <- GNET_pilot_alldata[is.na(count_test_sequence) & response == "left" & type != "prototype", .N/50, by=.(ID)]
StudyCR <- merge(StudySummary, StudyFA,by=c("ID"), all = TRUE)
colnames(StudyCR) <- c("ID","R","FA")
StudyCR[is.na(FA), FA:=0]
StudyCR[,CR := R - FA]
StudyBinom <- GNET_pilot_alldata[is.na(count_test_sequence) & response == "left",.(ID,response,type),]
StudyBinom$RespBinomial <- 0
handles <- unique(StudyBinom[,.(ID)])
StudyCR$CI_lower <- 0
StudyCR$CI_upper <- 0
for (i in 1:nrow(handles)){
tempBinData <- StudyBinom[ID == handles$ID[i],RespBinomial]
confint <- binconf(x=sum(tempBinData), n=length(tempBinData))
StudyCR[ID == handles$ID[i], CI_lower := confint[2]]
StudyCR[ID == handles$ID[i], CI_upper := confint[3]]
}
# exclusion crit based on corrected recog rate
StudySummary <- StudyCR[CR > 0] # 0.3 is the 20th percentile
# exclusion crit based on uncorrected recog rate
# StudySummary <- StudySummary[V1 > 0.5]
StudySummary <- StudyCR[CI_lower > 0.33]
ExcludePrototypeRecog <- nrow(MissedResSummary) - nrow(StudySummary)
GNET_pilot_alldata <- GNET_pilot_alldata[(ID %in% StudySummary$ID),]
# túl sok maybe response kipottyan
TestSummary <- GNET_pilot_alldata[!is.na(count_test_sequence) & response == "down", .N, by=.(ID)]
# this is the exclusion criterion for maybe responses
# originally set to 25
TestSummary <- TestSummary[N < 50]
ExcludeMaybeResp <- nrow(StudySummary) - nrow(TestSummary)
GNET_pilot_alldata <-
GNET_pilot_alldata[(ID %in% TestSummary$ID),]
GNET_pilot_filtered <- GNET_pilot_alldata
rm(GNET_pilot_alldata,ids,MissedResSummary,ResponsesSummary,StudySummary)
source("difference_innumbers.R")
