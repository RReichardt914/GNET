GNET_pilot_RUN1_alldata[str_detect(stim,"prototype"),type:="prototype"]
GNET_pilot_RUN1_alldata[str_detect(stim,"sarr[1-4]"),type:="sarr"]
GNET_pilot_RUN1_alldata[str_detect(stim,"sarrsha[1-4]"),type:="sarrsha"]
GNET_pilot_RUN1_alldata[str_detect(stim,"sarrcol[1-4]"),type:="sarrcol"]
GNET_pilot_RUN1_alldata[str_detect(stim,"sarrshacol[1-4]"),type:="sarrshacol"]
GNET_pilot_RUN1_alldata[str_detect(stim,"p[6-9]"),type:="diffarr"]
GNET_pilot_RUN1_alldata[str_detect(stim,"p10"),type:="diffarr"]
# trial quality
GNET_pilot_RUN1_alldata$tq <- ""
GNET_pilot_RUN1_alldata[is.na(count_test_sequence),tq:="study"]
GNET_pilot_RUN1_alldata[!is.na(count_test_sequence),tq:="test"]
GNET_pilot_RUN1_alldata[str_detect(stim,"[1-2].png") & tq == "test",tq:="old"]
GNET_pilot_RUN1_alldata[str_detect(stim,"[3-4].png") & tq == "test",tq:="new"]
# calculated indices
GNET_pilot_RUN1_alldata$DTF <- 0
