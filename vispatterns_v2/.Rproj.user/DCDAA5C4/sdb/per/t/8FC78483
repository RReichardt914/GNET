    "contents" : "---\ntitle: \"Graded Novelty Enoding Task - 4 shapes version\"\noutput:\n  html_document:\n    toc: true\n    toc_float: \n      collapsed: false\n    toc_depth: 4\n---\n```{r  include=FALSE}\nsource(\"difference_innumbers.R\")\n\nlibrary(ez)\nlibrary(ggplot2)\nlibrary(emmeans)\nlibrary(DescTools)\nlibrary(stats)\nlibrary(afex)\nlibrary(effsize)\nlibrary(Hmisc)\n```\n\n```{r  include=FALSE}\ngnet2_data <- as.data.table(read.csv(\"alldata_pilot2_alldiffind.csv\", encoding = \"UTF-8\", stringsAsFactors = FALSE))\ngnet2_data$DTF <- 0\ngnet2_data$DTAF <- 0\ngnet2_data$DTAN <- 0\ngnet2_data$DTN_byPhase <- 0\n\nfor (i in 1:nrow(gnet2_data)){\n  for (j in 1:nrow(difference_indices)){\n    if (grepl(difference_indices$pict[j],gnet2_data$stim[i])){\n      gnet2_data$DTF[i] <- difference_indices$DTF[j]\n      gnet2_data$DTAF[i] <- difference_indices$DTAF[j]\n      gnet2_data$DTAN[i] <- difference_indices$DTAN[j]\n      gnet2_data$DTN_byPhase[i] <- difference_indices$DTN_byPhase[j]\n    }\n  }\n}\n# at this point we have all the data with all of the calculated difference indicators\ngnet2_data[is.na(st_corr),st_corr := 0]\n\ngnet2_data$identifier <- paste(gnet2_data$workerId, \"_\", gnet2_data$studyResultId, sep=\"\")\n\n# GENERATE STUDY DT ####\n# correct study responses by type\nstudy_dat = gnet2_data[is.na(count_test_sequence), sum(st_corr),\n                       by=.(studyResultId,workerId,stimtype)]\n# all study trials by type\nstudy_TrialNrByType <- gnet2_data[is.na(count_test_sequence), .N,\n                                  by=.(studyResultId,workerId,stimtype)]\nstrecog <- merge(study_dat,study_TrialNrByType,by=c(\"studyResultId\",\"workerId\",\"stimtype\"))\ncolnames(strecog) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"CCategorization\",\"NrTrials\")\n# calculate correct categorization rate\nstrecog[, crrate := CCategorization/NrTrials]\nstrecog$identifier <- paste(strecog$workerId, \"_\", strecog$studyResultId, sep=\"\")\nrm(study_dat,study_TrialNrByType)\n#####\n\n# GENERATE TEST DT ####\ntest_dat <- gnet2_data[!is.na(count_test_sequence), .N, by=.(studyResultId,workerId,stimtype,test_quality,rt_corr)]\n\ntest_dat$identifier <- paste(test_dat$workerId, \"_\", test_dat$studyResultId, sep=\"\")\n\nmycols  = c(\"identifier\",\"stimtype\",\"test_quality\",\"rt_corr\")\nsetkeyv(test_dat,mycols)\ntest_dat_c <- test_dat[J(do.call(CJ,lapply(mycols,function(x)unique(get(x)))))]\nfor (i in 1:nrow(test_dat_c)){\n  if (is.na(test_dat_c$N[i])){\n    test_dat_c$N[i] <- 0\n  }\n}\n\nfna <- test_dat_c[is.na(rt_corr) & test_quality == \"fam\",]\nfna$workerId <- c(fna[,str_split(identifier, pattern = \"_\")][1])\nfna$studyResultId <- c(fna[,str_split(identifier, pattern = \"_\")][2])\ncolnames(fna) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"fam_NA\",\"identifier\")\nfc <- test_dat_c[rt_corr == 1 & test_quality == \"fam\",]\nfc$workerId <- c(fc[,str_split(identifier, pattern = \"_\")][1])\nfc$studyResultId <- c(fc[,str_split(identifier, pattern = \"_\")][2])\ncolnames(fc) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"fam_corr\",\"identifier\")\nff <- test_dat_c[rt_corr == 0 & test_quality == \"fam\",]\nff$workerId <- c(ff[,str_split(identifier, pattern = \"_\")][1])\nff$studyResultId <- c(ff[,str_split(identifier, pattern = \"_\")][2])\ncolnames(ff) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"fam_miss\",\"identifier\")\n\nnna <- test_dat_c[is.na(rt_corr) & test_quality == \"new\",]\nnna$workerId <- c(nna[,str_split(identifier, pattern = \"_\")][1])\nnna$studyResultId <- c(nna[,str_split(identifier, pattern = \"_\")][2])\ncolnames(nna) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"new_NA\",\"identifier\")\nnc <- test_dat_c[rt_corr == 1 & test_quality == \"new\",]\nnc$workerId <- c(nc[,str_split(identifier, pattern = \"_\")][1])\nnc$studyResultId <- c(nc[,str_split(identifier, pattern = \"_\")][2])\ncolnames(nc) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"new_corr\",\"identifier\")\nnf <- test_dat_c[rt_corr == 0 & test_quality == \"new\",]\nnf$workerId <- c(nf[,str_split(identifier, pattern = \"_\")][1])\nnf$studyResultId <- c(nf[,str_split(identifier, pattern = \"_\")][2])\ncolnames(nf) <- c(\"studyResultId\",\"workerId\",\"stimtype\",\"test_quality\",\"rt_corr\",\"new_fa\",\"identifier\")\n\nfams <- merge(fna,fc,by=c(\"stimtype\",\"test_quality\",\"identifier\"))\nfams <- merge(fams,ff,by=c(\"stimtype\",\"test_quality\",\"identifier\"))\nfams <- fams[,c(\"stimtype\",\"test_quality\",\"identifier\",\n                          \"fam_NA\",\"fam_corr\",\"studyResultId\",\n                          \"workerId\",\"fam_miss\")]\nfams$studyResultId <- as.character(fams$studyResultId)\nfams$workerId <- as.character(fams$workerId)\n\nnews <- merge(nna,nc,by=c(\"stimtype\",\"test_quality\",\"identifier\"))\nnews <- merge(news,nf,by=c(\"stimtype\",\"test_quality\",\"identifier\"))\nnews <- news[,c(\"stimtype\",\"test_quality\",\"identifier\",\n                \"new_NA\",\"new_corr\",\"studyResultId\",\"workerId\",\"new_fa\")]\nnews$studyResultId <- as.character(news$studyResultId)\nnews$workerId <- as.character(news$workerId)\n\ntest_dat_compl <- merge(fams,news,by=c(\"studyResultId\",\"workerId\",\"stimtype\",\"identifier\"))\ntest_dat_compl <- test_dat_compl[,c(\"studyResultId\",\"workerId\",\"stimtype\",\"identifier\",\n                                    \"fam_NA\",\"fam_corr\",\"fam_miss\",\n                                    \"new_NA\",\"new_corr\",\"new_fa\")]\nrm(nc,nf,news,nna,fc,ff,fna,fams)\n#####\n\n# strecog & test_dat_compl holds the data from st and rt\n```\n\n```{r  include=FALSE}\n#  this section is for exclusions\ntotal_runs <- nrow(gnet2_data[,.N,by=.(workerId,studyResultId)])\nusable <- gnet2_data[,.N,by=.(workerId,studyResultId)]\nusable <- usable[N == 175,]\nusable <- usable[order(studyResultId),]\nusable <- usable[!(duplicated(workerId)),]\nusable$identifier <- paste(usable$workerId, \"_\", usable$studyResultId, sep=\"\")\nfineids <- unique(usable$identifier)\n\ncrates <- strecog[stimtype == \"prototype\",c(\"identifier\",\"crrate\")]\n\n####\nStudySummary <- gnet2_data[is.na(count_test_sequence) & response == \"left\" & stimtype == \"prototype\", .N/25, by=.(workerId,studyResultId)]\nStudyFA <- gnet2_data[is.na(count_test_sequence) & response == \"left\" & stimtype != \"prototype\", .N/50, by=.(workerId,studyResultId)]\nStudyCR <- merge(StudySummary, StudyFA,by=c(\"workerId\",\"studyResultId\"), all = TRUE)\ncolnames(StudyCR) <- c(\"workerId\",\"studyResultId\",\"R\",\"FA\")\nStudyCR[is.na(FA), FA:=0]\nStudyCR[,CR := R - FA]\nrm(StudySummary,StudyFA)\n\nStudyBinom <- gnet2_data[is.na(count_test_sequence) & response == \"left\",.(workerId,studyResultId,response,stimtype),]\nStudyBinom$RespBinomial <- 0\nStudyBinom[stimtype == \"prototype\", RespBinomial := 1]\nhandles <- unique(StudyBinom[,.(workerId,studyResultId)])\nStudyCR$CI_lower <- 0\nStudyCR$CI_upper <- 0\nfor (i in 1:nrow(handles)){\n  tempBinData <- StudyBinom[workerId == handles$workerId[i] & studyResultId == handles$studyResultId[i],RespBinomial]\n  confint <- binconf(x=sum(tempBinData), n=length(tempBinData))\n  StudyCR[workerId == handles$workerId[i] & studyResultId == handles$studyResultId[i], CI_lower := confint[2]]\n  StudyCR[workerId == handles$workerId[i] & studyResultId == handles$studyResultId[i], CI_upper := confint[3]]\n}\n\ninsufficient_data <- nrow(StudyCR) - nrow(usable)\nStudyCR <- StudyCR[workerId %in% usable$workerId & studyResultId %in% usable$studyResultId,]\n\n# exclusion crit based on corrected recog rate\nStudySummary <- StudyCR[CR > 0] # 0.3 is the 20th percentile\n# exclusion crit based on uncorrected recog rate\n# StudySummary <- StudySummary[V1 > 0.5]\nStudySummary <- StudyCR[CI_lower > 0.33]\n\nExcludePrototypeRecog <- nrow(StudyCR) - nrow(StudySummary)\nStudySummary$identifier <- paste(StudySummary$workerId, \"_\", StudySummary$studyResultId, sep=\"\")\n\nstrecog <- strecog[identifier %in% StudySummary$identifier,]\ntest_dat_compl <- test_dat_compl[identifier %in% StudySummary$identifier,]\ngnet2_data <- gnet2_data[identifier %in% StudySummary$identifier,]\n\n# we need to add some zeros for the type*tq*rkey(response) combinations that are left out\n# this will be done after exclusions\n\nnorespfam <- test_dat_compl[,sum(fam_NA),by=c(\"identifier\")]\nnorespnew <- test_dat_compl[,sum(new_NA),by=c(\"identifier\")]\nnoresp <- merge(norespfam, norespnew, by=c(\"identifier\"))\nnoresp[,nor := V1.x + V1.y]\n\nnrlimit <- 20 # var the miss limit\nnoresp_ok <- noresp[nor <= nrlimit]\ndropbynoresp <- nrow(noresp) - nrow(noresp_ok)\n\nstrecog <- strecog[identifier %in% noresp_ok$identifier]\ntest_dat_compl <- test_dat_compl[identifier %in% noresp_ok$identifier]\ngnet2_data <- gnet2_data[identifier %in% noresp_ok$identifier]\n```\n\n# Exclusions\n\nIn total, the task was run `r total_runs` times.\n\n`r insufficient_data` runs were not completed or were duplicates.\n\nWe excluded `r ExcludePrototypeRecog` participants due to low performance in the study phase. We calculated the confidence intervals for the probability of correct \"old\" responses and excluded those participants whose lower CI was below 0.33 (chance level - 25 opportunities for correct \"old\" response, 50 for incorrect).\n\nWe excluded `r dropbynoresp` participants due to missed responses in test phase (<= `r nrlimit`).\n\nThis left `r length(unique(strecog$identifier))` participants in the analysis.\n\n```{r  include=FALSE}\n\ngnet2_register <- as.data.table(read.csv(\"gnet_v2_-_register.csv\", encoding = \"UTF-8\", stringsAsFactors = FALSE))\ncolnames(gnet2_register) <- c(\"datetime\",\"workerId\",\"age\",\"gen\",\n                              \"health\",\"sleep\",\"coffee\",\"smoke\",\"alcdrug\")\n\ngnet2_register <- gnet2_register[workerId %in% gnet2_data$workerId]\ngnet2_register <- gnet2_register[!(duplicated(workerId)),]\n```\n\nThe sample had a mean(±sd) age of `r mean(gnet2_register$age)` ± `r sd(gnet2_register$age)`.\n\nThe sample contained `r nrow(gnet2_register[gen == \"Nő\",])` women.\n\n# Comparison with GNET 1\n\n```{r  include=FALSE}\ngnet_data <- as.data.table(read.csv(\"gnet1_raw_data.csv\"))\ngnet_data$st_corr <- 0\ngnet_data[type == \"prototype\" & response == \"left\", st_corr := 1]\ngnet_data[type != \"prototype\" & response == \"right\", st_corr := 1]\ngnet1_study_dat <- gnet_data[is.na(count_test_sequence), sum(st_corr),\n                       by=.(studyResultId,workerId,type)]\ntemp <- gnet_data[is.na(count_test_sequence), .N,\n                       by=.(studyResultId,workerId,type)]\ngnet1_study_dat <- merge(gnet1_study_dat, temp, by=c(\"studyResultId\",\"workerId\",\"type\"))\ncolnames(gnet1_study_dat) <- c(\"studyResultId\",\"workerId\",\"type\",\"CCategorization\",\"NrTrials\")\ngnet1_study_dat[,ccrate := CCategorization/NrTrials]\nrm(temp)\n\n# GENERATE TEST DT ####\ngnet_data$rt_corr <- 0\ngnet_data[tq == \"old\" & response == \"left\", rt_corr :=1]\ngnet_data[tq == \"new\" & response == \"right\", rt_corr :=1]\ngnet_data[response == \"down\", rt_corr := NA]\ngnet_data[response == \"None\", rt_corr := NA]\n\ngnet1_test_dat <- gnet_data[!is.na(count_test_sequence), .N, by=.(studyResultId,workerId,type,tq,rt_corr)]\n\n# fill out nonexistent\ngnet1_test_dat$identifier <- paste(gnet1_test_dat$workerId, \"_\", gnet1_test_dat$studyResultId, sep=\"\")\nmycols  = c(\"identifier\",\"type\",\"tq\",\"rt_corr\")\nsetkeyv(gnet1_test_dat,mycols)\ngnet1_test_dat <- gnet1_test_dat[J(do.call(CJ,lapply(mycols,function(x)unique(get(x)))))]\nfor (i in 1:nrow(gnet1_test_dat)){\n  if (is.na(gnet1_test_dat$N[i])){\n    gnet1_test_dat$N[i] <- 0\n    gnet1_test_dat$workerId[i] <- str_split(gnet1_test_dat$identifier[i], pattern = \"_\")[[1]][1]\n    gnet1_test_dat$studyResultId[i] <- str_split(gnet1_test_dat$identifier[i], pattern = \"_\")[[1]][2]\n  }\n}\n\nold <- gnet1_test_dat[tq == \"old\",]\nnew <- gnet1_test_dat[tq == \"new\",]\noldcorr <- old[rt_corr == 1,]\ncolnames(oldcorr) <- c(\"studyResultId\",\"workerId\",\"type\",\"tq\",\"rt_corr\",\"fam_corr\",\"identifier\")\noldcorr <- oldcorr[,c(\"studyResultId\",\"workerId\",\"type\",\"fam_corr\")]\noldmiss <- old[rt_corr == 0,]\ncolnames(oldmiss) <- c(\"studyResultId\",\"workerId\",\"type\",\"tq\",\"rt_corr\",\"fam_miss\",\"identifier\")\noldmiss <- oldmiss[,c(\"studyResultId\",\"workerId\",\"type\",\"fam_miss\")]\nnewcorr <- new[rt_corr == 1,]\ncolnames(newcorr) <- c(\"studyResultId\",\"workerId\",\"type\",\"tq\",\"rt_corr\",\"new_corr\",\"identifier\")\nnewcorr <- newcorr[,c(\"studyResultId\",\"workerId\",\"type\",\"new_corr\")]\nnewmiss <- new[rt_corr == 0,]\ncolnames(newmiss) <- c(\"studyResultId\",\"workerId\",\"type\",\"tq\",\"rt_corr\",\"new_fa\",\"identifier\")\nnewmiss <- newmiss[,c(\"studyResultId\",\"workerId\",\"type\",\"new_fa\")]\n\nold <- merge(oldcorr,oldmiss,by=c(\"studyResultId\",\"workerId\",\"type\"))\nnew <- merge(newcorr,newmiss,by=c(\"studyResultId\",\"workerId\",\"type\"))\ngnet1_test_dat <- merge(old,new,by=c(\"studyResultId\",\"workerId\",\"type\"))\nrm(oldcorr,oldmiss,newcorr,newmiss,old,new)\n```\n\nThe recognition of the prototypes compared between studies (original GNET with 5 shapes).\n\na = original GNET\nb = 4 shapes GNET\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\na <- gnet1_study_dat[type == \"prototype\", ccrate]\nb <- strecog[stimtype == \"prototype\", crrate]\nprint(t.test(a,b,paired = FALSE))\nprint(cohen.d(a,b,paired = FALSE,conf.level=0.95))\n```\n\nThe distribution of the data is not normal (original GNET):\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(shapiro.test(a))\n```\n\nThe distribution of the data is not normal (current GNET):\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(shapiro.test(b))\n```\n\nUse a non-parametric alternative for the Welch test - Mann-Whitney-Wilcoxon U test\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(wilcox.test(a,b,conf.int=TRUE))\n```\n\nThe overall correct categorizations in the test phase\n\n```{r  include=FALSE}\n\ngnet1_test_dat[,famcat := fam_corr - new_fa]\ngnet1_test_dat[,newcat := new_corr - fam_miss]\ngnet1_test_dat[,occ := famcat + newcat]\na <- gnet1_test_dat[,mean(occ),by=workerId]\na <- a$V1\n\ngnet2_test_dat <- test_dat_compl\ngnet2_test_dat[,famcat := fam_corr - new_fa]\ngnet2_test_dat[,newcat := new_corr - fam_miss]\ngnet2_test_dat[,occ := famcat + newcat]\nb <- gnet2_test_dat[,mean(occ),by=workerId]\nb <- b$V1\n\n```\n\nThe distribution of the test data (original GNET):\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(shapiro.test(a))\n```\n\nThe distribution of the test data (4 shapes GNET):\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(shapiro.test(b))\n```\n\nThe performance on the recognition test compared with a Welch test\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nprint(t.test(a,b,paired = FALSE))\nprint(cohen.d(a,b,paired = FALSE,conf.level=0.95))\n```\n\n# Study phase\n\nANOVA to compare the rejection rate for each difference category; plot shows the prototype recog rate also.\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\n\n# We use an ANOVA to see if there is a difference in correct rejection for the different novels.\n# csak az újakra adott válaszok\n\n# ezANOVA(study_dat_news, dv =  crrate, within = type, wid = workerId)\na1 <- aov_ez(\"identifier\", \"crrate\",\n             strecog[stimtype != \"prototype\"], within = \"stimtype\")\nsummary(a1)\nm3 <- emmeans(a1, ~ stimtype)\npairs(m3)\ncontrast(m3, \"poly\")\n\n\nggplot(strecog, aes(x=stimtype, y=crrate, color = stimtype)) + \n  geom_jitter(width=0.2, alpha=0.2) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=5.0, aes( label=round(..y.., digits=3)))\n\n\n```\n\n# Test phase\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\n\n# BY RESPONSE TYPE\n\na <- test_dat_compl$fam_corr\nb <- test_dat_compl$new_fa\nprint(t.test(a,b,paired = TRUE))\nprint(cohen.d(a,b,paired = TRUE,conf.level=0.95))\nd <- with(test_dat_compl, fam_corr - new_fa)\nprint(shapiro.test(d))\nprint(wilcox.test(a,b,conf.int=TRUE))\n\nprint(\"Correct recognition for familiars in test\")\nggplot(test_dat_compl, aes(x=stimtype, y=fam_corr))+\n  geom_jitter(width=0.2, alpha=0.5) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=-3.0, aes( label=round(..y.., digits=3)))\n\nprint(\"False alarm for novels in test\")\nggplot(test_dat_compl, aes(x=stimtype, y=new_fa))+\n  geom_jitter(width=0.2, alpha=0.5) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=-3.0, aes( label=round(..y.., digits=3)))\n\ntest_dat_compl[,CorrectedRecognitions:=fam_corr-new_fa]\ntest_dat_compl[,CorrectedRejections:=new_corr-fam_miss]\ntest_dat_compl[,OCCategorizations := CorrectedRecognitions + CorrectedRejections]\n\nprint(\"ANOVA with correct recognition minus false alarm or miss by fam/nov\")\na1 <- aov_ez(\"identifier\", \"CorrectedRecognitions\",\n             test_dat_compl, within = c(\"stimtype\"))\nsummary(a1)\nm3 <- emmeans(a1, ~ stimtype)\npairs(m3)\nposthoc <- pairs(m3)\ncontrast(m3, \"poly\")\n\nggplot(test_dat_compl, aes(x=stimtype, y=CorrectedRecognitions, color=stimtype))+\n  geom_jitter(width=0.2, alpha=0.5) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=-3.0, aes( label=round(..y.., digits=3))) +\n  xlab(\"\") +\n  ylab(\"Korrigált felismerés\") +\n  labs(color = \"Kategória\")\n\nprint(\"ANOVA with correct rejection minus false alarm or miss by fam/nov\")\na1 <- aov_ez(\"identifier\", \"CorrectedRejections\",\n             test_dat_compl, within = c(\"stimtype\"))\nsummary(a1)\nm3 <- emmeans(a1, ~ stimtype)\npairs(m3)\nposthoc <- pairs(m3)\ncontrast(m3, \"poly\")\n\nggplot(test_dat_compl, aes(x=stimtype, y=CorrectedRejections, color=stimtype))+\n  geom_jitter(width=0.2, alpha=0.5) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=-3.0, aes( label=round(..y.., digits=3))) +\n  xlab(\"\") +\n  ylab(\"Korrigált elutasítás\") +\n  labs(color = \"Kategória\")\n\nprint(\"ANOVA with corrected differentiation score by category ((crecog-fa)+(creject-fa))\")\na1 <- aov_ez(\"identifier\", \"OCCategorizations\",\n             test_dat_compl, within = c(\"stimtype\"))\nsummary(a1)\nm3 <- emmeans(a1, ~ stimtype)\npairs(m3)\nposthoc <- pairs(m3)\ncontrast(m3, \"poly\")\n\nggplot(test_dat_compl, aes(x=stimtype, y=OCCategorizations, color=stimtype))+\n  geom_jitter(width=0.2, alpha=0.5) +\n  stat_summary(geom = \"errorbar\", fun.data = mean_se, width = 0.2) +\n  stat_summary(geom = \"point\",fun.y = \"mean\",col = \"black\",size = 2,shape = 16) +\n  stat_summary(fun.y=mean, colour=\"black\", geom=\"text\", show.legend = FALSE, \n               vjust=-3.0, aes( label=round(..y.., digits=3))) +\n  xlab(\"\") +\n  ylab(\"Összes korrigált kategorizáció\") +\n  labs(color = \"Kategória\")\n\n\n```\n\n# Mixed models\n\n```{r  include=FALSE}\nlibrary(lme4)\nlibrary(lmerTest)\nlibrary(sjPlot)\n\n\nlmmdat <- gnet2_data\n\nstlmm <- lmmdat[is.na(test_quality),]\n\ntdlmm <- lmmdat[!(is.na(test_quality)),]\n\n\n```\n\n## Test phase\n\n### Models #1\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\ntdlmm$rt_resp <- NA\ntdlmm[response_test_response == \"left\", rt_resp := 0]\ntdlmm[response_test_response == \"right\", rt_resp := 1]\ntdlmm$rt_resp <- as.numeric(tdlmm$rt_resp)\ntdlmm$stimtype <- factor(tdlmm$stimtype)#, ordered = TRUE, levels=c(\"D1\",\"D2\",\"D3\",\"D4\",\"D5\"))\ntdlmm$trial_quality <- as.factor(tdlmm$trial_quality)\ntdlmm$rt_corr <- as.numeric(tdlmm$rt_corr)\n\nlogmr <- glmer(rt_resp ~ stimtype * test_quality + (1|workerId),\n               data = tdlmm,\n               family = binomial,\n               control = lmerControl(optCtrl=list(xtol_abs=1e-8, ftol_abs=1e-8, maxeval=100000)))\nsummary(logmr)\nplot_model(logmr, type = \"eff\")\nplot_model(logmr, type = \"int\")\n\nlogmr2 <- glmer(rt_resp ~ DTF * test_quality + (1|workerId),\n               data = tdlmm,\n               family = binomial)\nsummary(logmr2)\nplot_model(logmr2, type = \"eff\")\nplot_model(logmr2, type = \"int\")\n\nlogmr3 <- glmer(rt_resp ~ DTAF * test_quality + (1|workerId),\n               data = tdlmm,\n               family = binomial)\nsummary(logmr3)\nplot_model(logmr3, type = \"eff\")\nplot_model(logmr3, type = \"int\")\n\nlogmr4 <- glmer(rt_resp ~ DTAN * test_quality + (1|workerId),\n               data = tdlmm,\n               family = binomial)\nsummary(logmr4)\nplot_model(logmr4, type = \"eff\")\nplot_model(logmr4, type = \"int\")\n\nlogmr5 <- glmer(rt_resp ~ DTN_byPhase * test_quality + (1|workerId),\n               data = tdlmm,\n               family = binomial)\nsummary(logmr5)\nplot_model(logmr5, type = \"eff\")\nplot_model(logmr5, type = \"int\")\n\n# logmr6 <- glmer(rt_resp ~ DTN * tq + (tq|workerId),\n#               data = tdlmm,\n#                family = binomial)\n# summary(logmr6)\n# plot_model(logmr6, type = \"eff\")$DTN\n# plot_model(logmr6, type = \"eff\")$tq\n# plot_model(logmr6, type = \"int\")\n\ntab_model(logmr, logmr2,logmr3,logmr4,logmr5,#logmr6,\n          # = c(\"Model 1\", \"Model 2\", \"Model 3\", \"Model 4\"),\n          show.est = TRUE,\n          # show.ci = TRUE,\n          show.se = TRUE,\n          show.r2 = TRUE,\n          # show.adj.icc = TRUE,\n          # show.icc = FALSE,\n          # pred.labels =\n          show.aic = TRUE,\n          show.aicc = TRUE,\n          # show.std = TRUE,\n          transform = NULL)\n```\n\n## Study response - test resp mdl\n\n```{r  eval = TRUE, warning=FALSE, echo=FALSE}\nbdlmm <- merge(stlmm, tdlmm, by=c(\"workerId\", \"stim\"))\n\nlogmr <- glmer(rt_resp ~ st_corr.x * stimtype.x + (1|workerId),\n               data = bdlmm,\n               family = binomial,\n               control = lmerControl(optCtrl=list(xtol_abs=1e-8, ftol_abs=1e-8, maxeval=100000)))\nsummary(logmr)\nplot_model(logmr, type = \"eff\")\nplot_model(logmr, type = \"int\")\n```",
