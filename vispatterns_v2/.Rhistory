plot(gnet2_data[!(is.na(rt_corr)),sum(rt_corr),by=c("stim")])
ggplot(gnet2_data[!(is.na(rt_corr)),sum(rt_corr),by=c("stim")],aes(V1,stim)) + geom_col()
gnet2_data[!(is.na(rt_corr)),sum(rt_corr),by=c("stim")]>20
ggplot(dat[V1 > 20],aes(V1,stim)) + geom_col()
dat <- gnet2_data[!(is.na(rt_corr)),sum(rt_corr),by=c("stim")]
ggplot(dat[V1 > 20],aes(V1,stim)) + geom_col()
ggplot(dat[V1 > 30],aes(V1,stim)) + geom_col()
ggplot(dat[V1 > 40],aes(V1,stim)) + geom_col()
