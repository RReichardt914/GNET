library(sjPlot)
lmmdat <- gnet2_data
stlmm <- lmmdat[is.na(test_quality),]
tdlmm <- lmmdat[!(is.na(test_quality)),]
tdlmm$rt_resp <- NA
tdlmm[response_test_response == "left", rt_resp := 0]
tdlmm[response_test_response == "right", rt_resp := 1]
tdlmm$rt_resp <- as.numeric(tdlmm$rt_resp)
tdlmm$stimtype <- factor(tdlmm$stimtype)#, ordered = TRUE, levels=c("D1","D2","D3","D4","D5"))
tdlmm$trial_quality <- as.factor(tdlmm$trial_quality)
tdlmm$rt_corr <- as.numeric(tdlmm$rt_corr)
View(tdlmm)
View(stlmm)
bdlmm <- merge(stlmm, tdlmm, by=c("workerId", "stim"))
View(bdlmm)
bdlmm <- merge(stlmm, tdlmm, by=c("workerId", "stim"))
logmr <- glmer(rt_resp ~ st_corr.x + stimtype * test_quality + (1|workerId),
data = bdlmm,
family = binomial,
control = lmerControl(optCtrl=list(xtol_abs=1e-8, ftol_abs=1e-8, maxeval=100000)))
logmr <- glmer(rt_resp ~ st_corr.x * stimtype + (1|workerId),
data = bdlmm,
family = binomial,
control = lmerControl(optCtrl=list(xtol_abs=1e-8, ftol_abs=1e-8, maxeval=100000)))
logmr <- glmer(rt_resp ~ st_corr.x * stimtype.x + (1|workerId),
data = bdlmm,
family = binomial,
control = lmerControl(optCtrl=list(xtol_abs=1e-8, ftol_abs=1e-8, maxeval=100000)))
summary(logmr)
plot_model(logmr, type = "eff")
plot_model(logmr, type = "int")
