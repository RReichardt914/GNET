# Load data
df <- read.csv("your_file.csv", header = TRUE, stringsAsFactors = FALSE)

# Extract group ID (prefix before 'col' or 'sha')
df$group_id <- sub("(.*)(col|sha)?$", "\\1", df[[1]])

# Split into groups
library(dplyr)
grouped <- df %>%
  group_by(group_id) %>%
  group_split()

# Convert each group into a list of vectors
group_vectors <- lapply(grouped, function(group) {
  vectors <- as.matrix(group[, 2:10])
  rownames(vectors) <- group[[1]]
  return(list(id = unique(group$group_id), vectors = vectors))
})

# Define a pattern matching function
# Example: check if vector 2 has value 2 in positions 1 to 5
match_pattern <- function(group, vector_index = 2, positions = 1:5, value = 2) {
  vec <- group$vectors[vector_index, ]
  all(vec[positions] == value)
}

# Apply pattern across all groups
pattern_matches <- sapply(group_vectors, match_pattern)

# Calculate frequency
pattern_count <- sum(pattern_matches)
total_groups <- length(group_vectors)
pattern_frequency <- pattern_count / total_groups

# Assign frequency to matching groups
group_frequencies <- sapply(pattern_matches, function(match) if (match) pattern_frequency else NA)

# Combine results
results <- data.frame(
  group_id = sapply(group_vectors, function(g) g$id),
  pattern_match = pattern_matches,
  frequency = group_frequencies
)

# View results
print(results)
